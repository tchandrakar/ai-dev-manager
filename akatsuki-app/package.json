{
  "name": "akatsuki",
  "version": "0.1.0",
  "description": "Akatsuki — AI-powered code review for developers. Sharingan module.",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "install-app": "electron-forge package && APP=$(find out -name 'Akatsuki.app' -maxdepth 3 | head -1) && rm -rf '/Applications/Akatsuki.app' && cp -r \"$APP\" /Applications/ && echo '✓ Installed to /Applications/Akatsuki.app'"
  },
  "author": "tchandrakar",
  "license": "MIT",
  "type": "commonjs",
  "config": {
    "forge": "./forge.config.cjs"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "better-sqlite3": "^11.5.0",
    "ioredis": "^5.10.0",
    "mongodb": "^7.1.0",
    "mssql": "^12.2.0",
    "mysql2": "^3.19.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.17.0",
    "three": "^0.183.2"
  }
}
